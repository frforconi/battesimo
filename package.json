{
  "name": "drive-gallery",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "api"
  ],
  "scripts": {
    "build": "npm run build -w frontend",
    "dev:api": "npm run dev -w api",
    "dev:frontend": "npm run start -w frontend",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
