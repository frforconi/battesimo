{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*\\.[a-z0-9]+)$",
      "destination": "/frontend/dist/browser/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/browser/index.html"
    }
  ]
}
